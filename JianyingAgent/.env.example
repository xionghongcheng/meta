# Copy this file to .env on each machine and adjust local paths.

# FFmpeg. setup.ps1 can auto-download this into vendor/ffmpeg.
FFMPEG_PATH=vendor/ffmpeg/bin/ffmpeg.exe
FFPROBE_PATH=vendor/ffmpeg/bin/ffprobe.exe

# Jianying draft output.
JIANYING_DRAFT_ROOT=E:/JianyingPro Drafts
JIAN_YING_PROJECT_DIR=%USERPROFILE%/Documents/JianyingPro/User Data/Projects

# Project runtime directories
JIANYING_INPUT_DIR=input
JIANYING_OUTPUT_DIR=output
JIANYING_TEMP_DIR=temp

# Local Hugging Face cache for faster-whisper models.
HF_HOME=vendor/hf-cache
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Codex/OpenAI provider.
# If this machine has Codex configured, these can be left empty.
OPENAI_API_KEY=
OPENAI_RESPONSES_URL=
CODEX_MODEL=
CODEX_REASONING_EFFORT=medium
CODEX_TIMEOUT_SECONDS=300
